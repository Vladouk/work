# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=your_telegram_user_id_here

# Database
DATABASE_URL=postgresql://postgres:111@localhost:5432/jobhunter


# AI - supports OpenAI or Gemini
# For Gemini (free): get key at https://aistudio.google.com
OPENAI_API_KEY=your_gemini_or_openai_api_key_here
OPENAI_MODEL=gemini-2.0-flash
# Leave empty for OpenAI, set this URL for Gemini:
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# App
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Cron
CRON_SCHEDULE=*/30 * * * *

# Parser timeouts (ms)
PARSER_TIMEOUT=30000
PARSER_MAX_RETRIES=3
